<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Моё расписание</title>
  <style>
    body { font-family: Arial, sans-serif; background: #f5f6fa; margin: 0; }
    .header { background: #667eea; color: white; padding: 15px 25px; display: flex; justify-content: space-between; }
    .header a { color: white; text-decoration: none; font-size: 14px; margin-left: 10px; }
    .menu { background: white; padding: 10px 25px; display: flex; gap: 15px; flex-wrap: wrap; }
    .menu a { text-decoration: none; color: #555; font-size: 14px; }
    .menu a.active { color: #667eea; font-weight: bold; }
    .content { padding: 25px; max-width: 900px; margin: 0 auto; }
    .cal { display: grid; grid-template-columns: repeat(7, 1fr); gap: 5px; margin-bottom: 25px; }
    .cal .day { padding: 12px 6px; text-align: center; border-radius: 8px; background: #fafafa; cursor: pointer; }
    .cal .day:hover { background: #eef2ff; }
    .cal .day.today { border: 2px solid #667eea; font-weight: bold; }
    .cal .day.selected { background: #667eea; color: white; }
    .cal .day.has::after { content: "●"; color: #e74c3c; font-size: 10px; display: block; }
    .nav { display: flex; justify-content: space-between; margin-bottom: 15px; }
    .nav button { background: #667eea; color: white; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; }
    .nav span { font-weight: bold; font-size: 18px; }
    .card { background: white; padding: 20px; border-radius: 12px; }
    .lesson-item { padding: 12px; margin: 6px 0; border-radius: 8px; background: #eef2ff; border-left: 3px solid #667eea; }
  </style>
</head>
<body>
  <div class="header"><strong>📚 Кабинет ученика</strong><span>👋 <%= user.name %> <a href="/student/profile">👤</a> <a href="/logout">Выйти</a></span></div>
  <div class="menu">
    <a href="/student/dashboard">🏠 Главная</a>
    <a href="/student/calendar" class="active">📅 Расписание</a>
    <a href="/student/lessons">📖 Занятия</a>
    <a href="/student/homeworks">📝 ДЗ</a>
    <a href="/student/library">📚 Материалы</a>
    <a href="/student/profile">👤 Профиль</a>
  </div>
  <div class="content">
    <div class="nav">
      <button onclick="ch(-1)">←</button>
      <span id="ml"></span>
      <button onclick="ch(1)">→</button>
    </div>
    <div class="cal" id="cal"></div>
    <div class="card">
      <h3 id="sd">Выберите дату</h3>
      <div id="list"><p style="color:#888;">Нажмите на день</p></div>
    </div>
  </div>
  <script>
    let cur = new Date(), sel = null, lessons = <%- JSON.stringify(lessons) %>;
    function render() {
      let y=cur.getFullYear(), m=cur.getMonth(), first=new Date(y,m,1), off=first.getDay()-1;
      if(off<0) off=6;
      let days=new Date(y,m+1,0).getDate(), now=new Date().toISOString().slice(0,10), html='';
      document.getElementById('ml').textContent=first.toLocaleString('ru',{month:'long',year:'numeric'});
      for(let i=0;i<off;i++) html+='<div></div>';
      for(let d=1;d<=days;d++){
        let ds=y+'-'+String(m+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
        let cls='day'; if(ds===now) cls+=' today'; if(ds===sel) cls+=' selected';
        if(lessons.some(l=>(l.date_time||'').startsWith(ds))) cls+=' has';
        html+='<div class="'+cls+'" onclick="pick(\''+ds+'\')">'+d+'</div>';
      }
      document.getElementById('cal').innerHTML=html;
    }
    function ch(n) { cur.setMonth(cur.getMonth()+n); render(); }
    function pick(d) {
      sel=d; document.getElementById('sd').textContent='📅 '+d;
      let day=lessons.filter(l=>(l.date_time||'').startsWith(d));
      document.getElementById('list').innerHTML=day.length?day.map(l=>'<div class="lesson-item"><strong>'+(l.date_time||'').slice(11,16)+'</strong> — '+(l.topic||'Без темы')+' ('+l.duration+' мин)</div>').join(''):'<p style="color:#888;">Нет занятий</p>';
      render();
    }
    render();
  </script>
</body>
</html>