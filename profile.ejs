<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Профиль</title>
  <style>
    body { font-family: Arial, sans-serif; background: #f5f6fa; margin: 0; }
    .header { background: #667eea; color: white; padding: 15px 25px; display: flex; justify-content: space-between; }
    .header a { color: white; text-decoration: none; font-size: 14px; margin-left: 10px; }
    .menu { background: white; padding: 10px 25px; display: flex; gap: 15px; flex-wrap: wrap; }
    .menu a { text-decoration: none; color: #555; font-size: 14px; }
    .menu a.active { color: #667eea; font-weight: bold; }
    .content { padding: 25px; max-width: 500px; margin: 0 auto; }
    .card { background: white; padding: 25px; border-radius: 12px; text-align: center; }
    .avatar { width: 100px; height: 100px; border-radius: 50%; background: #667eea; color: white; font-size: 40px; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px; overflow: hidden; }
    .avatar img { width: 100px; height: 100px; object-fit: cover; }
    .btn { padding: 10px 20px; background: #667eea; color: white; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; margin-top: 10px; }
    input { width: 100%; padding: 10px; margin: 8px 0; border: 1px solid #ddd; border-radius: 6px; }
    .success { background: #e8f5e9; color: #27ae60; padding: 10px; border-radius: 6px; margin-bottom: 15px; }
    .info { text-align: left; margin-top: 20px; }
    .info p { padding: 8px 0; border-bottom: 1px solid #eee; color: #555; }
  </style>
</head>
<body>
  <div class="header"><strong>📚 Кабинет ученика</strong><span>👋 <%= user.name %> <a href="/student/dashboard">🏠</a> <a href="/logout">Выйти</a></span></div>
  <div class="menu">
    <a href="/student/dashboard">🏠 Главная</a>
    <a href="/student/calendar">📅 Расписание</a>
    <a href="/student/lessons">📖 Занятия</a>
    <a href="/student/homeworks">📝 ДЗ</a>
    <a href="/student/library">📚 Материалы</a>
    <a href="/student/profile" class="active">👤 Профиль</a>
  </div>
  <div class="content">
    <h2>👤 Профиль</h2>
    <% if (success) { %><div class="success"><%= success %></div><% } %>
    <div class="card">
      <div class="avatar"><% if (user.avatar&&user.avatar!=='default.png') { %><img src="/uploads/<%= user.avatar %>"><% } else { %><%= user.name.charAt(0).toUpperCase() %><% } %></div>
      <form action="/student/update-avatar" method="POST" enctype="multipart/form-data">
        <input type="file" name="avatar" accept="image/*" required><br>
        <button class="btn">📷 Загрузить фото</button>
      </form>
      <div class="info">
        <p><strong>Имя:</strong> <%= user.name %></p>
        <p><strong>Email:</strong> <%= user.email %></p>
        <p><strong>Телефон:</strong> <%= user.phone||'—' %></p>
      </div>
    </div>

    <div class="card" style="margin-top:15px;">
      <h3>🔒 Сменить пароль</h3>
      <form action="/student/change-password" method="POST">
        <input type="password" name="newpass" placeholder="Новый пароль" required>
        <button class="btn">Сохранить</button>
      </form>
    </div>
  </div>
</body>
</html>