<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Карточка ученика</title>
  <style>
    body { font-family: Arial, sans-serif; background: #f5f6fa; margin: 0; }
    .header { background: #667eea; color: white; padding: 15px 25px; display: flex; justify-content: space-between; }
    .header a { color: white; text-decoration: none; font-size: 14px; }
    .menu { background: white; padding: 10px 25px; display: flex; gap: 15px; }
    .menu a { text-decoration: none; color: #555; font-size: 14px; }
    .content { padding: 25px; max-width: 800px; margin: 0 auto; }
    .card { background: white; padding: 20px; border-radius: 12px; margin-bottom: 15px; }
    input, textarea { width: 100%; padding: 8px; margin: 5px 0; border: 1px solid #ddd; border-radius: 6px; }
    .btn { padding: 8px 16px; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; color: white; }
    .btn-purple { background: #667eea; }
    .btn-green { background: #27ae60; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 10px; border-bottom: 1px solid #eee; font-size: 14px; }
    .back { color: #667eea; text-decoration: none; font-size: 14px; }
  </style>
</head>
<body>
  <div class="header"><strong>📚 Кабинет репетитора</strong><span>👋 <%= user.name %> <a href="/logout">Выйти</a></span></div>
  <div class="menu">
    <a href="/teacher/dashboard">🏠 Главная</a>
    <a href="/teacher/calendar">📅 Расписание</a>
    <a href="/teacher/students">👩‍🎓 Ученики</a>
    <a href="/teacher/check-homeworks">📝 На проверку</a>
    <a href="/teacher/finances">💰 Финансы</a>
    <a href="/teacher/receipts">🧾 Счета</a>
  </div>
  <div class="content">
    <a href="/teacher/students" class="back">← Назад</a>
    <h2><%= student.name %></h2>
    <p style="color:#999;"><%= student.email %></p>
    <p style="color:#555;">📞 <%= student.phone || '—' %> | 👨‍👩‍👧 <%= student.parent_phone || '—' %></p>
    <p style="color:#888; font-size:13px;">📝 <%= student.notes || 'Нет заметок' %></p>
    <a href="/teacher/generate-telegram-link/<%= student.id %>" style="color:#667eea; font-size:13px;">🔗 Ссылка для Telegram</a>

    <div class="card" style="margin-top:15px;">
      <h3>✏️ Редактировать</h3>
      <form action="/teacher/update-student/<%= student.id %>" method="POST">
        <input type="text" name="name" value="<%= student.name %>" required>
        <input type="email" name="email" value="<%= student.email %>" required>
        <input type="text" name="phone" value="<%= student.phone||'' %>" placeholder="Телефон ученика">
        <input type="text" name="parent_phone" value="<%= student.parent_phone||'' %>" placeholder="Телефон родителя">
        <input type="text" name="notes" value="<%= student.notes||'' %>" placeholder="Заметки">
        <button class="btn btn-purple">Сохранить</button>
      </form>
    </div>

    <div class="card">
      <h3>➕ Выдать ДЗ</h3>
      <form action="/teacher/add-homework" method="POST">
        <input type="hidden" name="student_id" value="<%= student.id %>">
        <input type="text" name="title" placeholder="Название" required>
        <input type="date" name="deadline">
        <button class="btn btn-purple">Выдать</button>
      </form>
    </div>

    <div class="card">
      <h3>➕ Оплата</h3>
      <form action="/teacher/add-payment" method="POST">
        <input type="hidden" name="student_id" value="<%= student.id %>">
        <input type="number" name="amount" placeholder="Сумма" required>
        <input type="date" name="date" required>
        <button class="btn btn-green">Добавить</button>
      </form>
    </div>

    <div class="card">
      <h3>📋 ДЗ</h3>
      <table><tr><th>Название</th><th>Срок</th><th>Статус</th></tr>
      <% homeworks.forEach(function(h){ %><tr><td><%= h.title %></td><td><%= h.deadline||'—' %></td><td><%= h.status %></td></tr><% }) %></table>
    </div>

    <div class="card">
      <h3>💰 Оплаты</h3>
      <table><tr><th>Дата</th><th>Сумма</th></tr>
      <% payments.forEach(function(p){ %><tr><td><%= p.date %></td><td><%= p.amount %> BYN</td></tr><% }) %></table>
    </div>
  </div>
</body>
</html>