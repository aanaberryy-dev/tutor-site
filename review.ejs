<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Проверка ДЗ</title>
  <style>
    body { font-family: Arial, sans-serif; background: #f5f6fa; margin: 0; }
    .header { background: #667eea; color: white; padding: 15px 25px; display: flex; justify-content: space-between; }
    .header a { color: white; text-decoration: none; font-size: 14px; }
    .menu { background: white; padding: 10px 25px; display: flex; gap: 15px; }
    .menu a { text-decoration: none; color: #555; font-size: 14px; }
    .content { padding: 25px; max-width: 600px; margin: 0 auto; }
    .card { background: white; padding: 25px; border-radius: 12px; }
    input, textarea { width: 100%; padding: 10px; margin: 10px 0; border: 1px solid #ddd; border-radius: 6px; }
    .btn { width: 100%; padding: 12px; background: #27ae60; color: white; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; }
    .back { color: #667eea; text-decoration: none; font-size: 14px; }
  </style>
</head>
<body>
  <div class="header"><strong>📚 Кабинет репетитора</strong><span>👋 <%= user.name %> <a href="/logout">Выйти</a></span></div>
  <div class="menu">
    <a href="/teacher/dashboard">🏠 Главная</a>
    <a href="/teacher/calendar">📅 Расписание</a>
    <a href="/teacher/students">👩‍🎓 Ученики</a>
    <a href="/teacher/check-homeworks">📝 На проверку</a>
    <a href="/teacher/finances">💰 Финансы</a>
  </div>
  <div class="content">
    <a href="/teacher/check-homeworks" class="back">← Назад</a>
    <div class="card">
      <h2><%= homework.title %></h2>
      <p>Ученик: <strong><%= homework.student_name %></strong></p>
      <p>Срок: <%= homework.deadline||'—' %></p>
      <% if (homework.file) { %><p>📎 <a href="/uploads/<%= homework.file %>" target="_blank">Файл ученика</a></p><% } %>
      <hr>
      <form action="/teacher/submit-review" method="POST">
        <input type="hidden" name="homework_id" value="<%= homework.id %>">
        <input type="text" name="grade" placeholder="Оценка">
        <textarea name="feedback" placeholder="Комментарий"></textarea>
        <button class="btn">✅ Отправить</button>
      </form>
    </div>
  </div>
</body>
</html>